# ── Server Environment Variables ────────────────────────────
# Copy this to .env and fill in your values

# Server
PORT=3001
CLIENT_URL=http://localhost:5173

# DeepSeek API (get your free key at https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-key-here

# Firebase Admin (paste the full JSON string of your service account)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Supabase (use the service_role key from Settings > API, NOT the anon key)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
