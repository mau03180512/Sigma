# ── Server Environment Variables ────────────────────────────
# Copy this to .env and fill in your values

# Server
PORT=3001
CLIENT_URL=http://localhost:5173

# Groq API (free, get your key at https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_key_here

# Firebase Admin (paste the full JSON string of your service account)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Supabase (use the service_role key from Settings > API, NOT the anon key)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
